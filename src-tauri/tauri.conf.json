{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YuLing DeskPet",
  "version": "0.1.0",
  "identifier": "com.lishouhai.yuling",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "隅灵",
        "width": 168,
        "height": 168,
        "minWidth": 168,
        "minHeight": 168,
        "maxWidth": 168,
        "maxHeight": 168,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "fullscreen": false,
        "center": false,
        "visible": true
      },
      {
        "label": "reminder",
        "title": "隅灵提醒",
        "url": "reminder.html",
        "width": 420,
        "height": 540,
        "minWidth": 420,
        "minHeight": 540,
        "maxWidth": 420,
        "maxHeight": 540,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
